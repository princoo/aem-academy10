<?xml version="1.0" encoding="UTF-8"?>
<jcr:root
    xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:cq="http://www.day.com/jcr/cq/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    heroBannerVariant="heroBanner--variant-1">

    <pretitle
        jcr:primaryType="nt:unstructured"
        sling:resourceType="wknd/components/atomics/title"
        placeholder="Edit Pretitle"
        titleSize="title-md"
        titleColor="text-primary"
    />
    <title
        jcr:primaryType="nt:unstructured"
        sling:resourceType="wknd/components/atomics/title"
        placeholder="Edit Main Title"
        titleSize="title-xl"
        titleColor="text-primary"
    />

    <cta-1
        jcr:primaryType="nt:unstructured"
        sling:resourceType="wknd/components/atomics/button"
        placeholder="Configure Button"
        type="primary"
        iconType="icon-academy-arrow_forward"
        buttonWidth="btn--width-standard"
    />
    <teaserImage
        jcr:primaryType="nt:unstructured"
        sling:resourceType="wknd/components/atomics/image"
        borderRadius="cmp-atomic-image--rounded"
        aspectRatio="cmp-atomic-image--ratio-16-9"
        lazyLoading="{Boolean}false"
        isDecorative="{Boolean}false"
        altValueFromDAM="{Boolean}true"
        titleValueFromDAM="{Boolean}true"
        displayPopupTitle="{Boolean}false"
    />
    <textInput
        jcr:primaryType="nt:unstructured"
        sling:resourceType="wknd/components/atomics/text"
        placeholder="Edit caption"
        textStyle="text-normal"
    />
</jcr:root>