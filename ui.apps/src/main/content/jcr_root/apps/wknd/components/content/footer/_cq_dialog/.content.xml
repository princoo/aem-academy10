<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Footer Settings"
    sling:resourceType="cq/gui/components/authoring/dialog"
    extraClientlibs="[wknd.components.footer.editor]"
>
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">

                    <mainColumnsTab
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Main Columns"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columnCount
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Number of Columns"
                                name="./columnCount">
                                <items jcr:primaryType="nt:unstructured">
                                    <one jcr:primaryType="nt:unstructured"
                                        text="1 Column" value="1" />
                                    <two jcr:primaryType="nt:unstructured"
                                        text="2 Columns" value="2" />
                                    <three jcr:primaryType="nt:unstructured"
                                        text="3 Columns" value="3" />
                                    <four jcr:primaryType="nt:unstructured"
                                        text="4 Columns" value="4"
                                        selected="{Boolean}true" />
                                </items>
                            </columnCount>
                        </items>
                    </mainColumnsTab>

                    <bottomBarTab
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Bottom Bar"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">

                            <copyright
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Copyright Text"
                                fieldDescription="e.g., © 2024 Università Cattolica del Sacro Cuore"
                                name="./copyrightText"
                                required="{Boolean}true" />

                            <utilsLinks
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                composite="{Boolean}true"
                                fieldLabel="Utility Links (Privacy, Cookies, etc.)">
                                <field
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                    name="./utilsLinks">
                                    <items jcr:primaryType="nt:unstructured">
                                        <linkText
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                            fieldLabel="Utility Link Text"
                                            name="./linkText"
                                            required="{Boolean}true" />
                                        <linkUrl
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                            fieldLabel="Utility Link URL"
                                            name="./linkUrl"
                                            rootPath="/content"
                                            required="{Boolean}true" />
                                    </items>
                                </field>
                            </utilsLinks>

                        </items>
                    </bottomBarTab>

                </items>
            </tabs>
        </items>
    </content>
</jcr:root>