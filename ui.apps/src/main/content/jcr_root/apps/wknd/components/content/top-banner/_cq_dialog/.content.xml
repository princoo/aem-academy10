<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Top Banner Settings"
    xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
    extraClientlibs="[wknd.components.topBar.editor]"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <slidesTab
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Slides"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <sliderCount
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                                fieldLabel="Number of Sliders"
                                                fieldDescription="Enter how many sliders you want."
                                                name="./sliderCount"
                                                min="1"
                                                max="6"
                                                granite:class="cq-dialog-slider-count" />
                                            <autoplaySpeed
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                                fieldLabel="Transition Timing (milliseconds)"
                                                fieldDescription="Example: 5000 = 5 seconds"
                                                name="./autoplaySpeed"
                                                min="1000"
                                                defaultValue="5000" />
                                            <!-- <activeSlider
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                fieldLabel="Select Active Slider"
                                                fieldDescription="Choose which slider to configure."
                                                name="./activeSlider"
                                                granite:class="cq-dialog-slider-select">
                                                <items jcr:primaryType="nt:unstructured" />
                                            </activeSlider> -->
                                            <slideVisibility
                                                jcr:primaryType="nt:unstructured"
                                                jcr:title="Slide Visibility &amp; Order (Publish Mode)"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/fieldset">
                                                <items jcr:primaryType="nt:unstructured">

                                                    <hideSlide1
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                        name="./hideSlide1"
                                                        text="Hide Slide 1"
                                                        value="true"
                                                        uncheckedValue="false" />


                                                    <hideSlide2
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                        name="./hideSlide2"
                                                        text="Hide Slide 2"
                                                        value="true"
                                                        uncheckedValue="false" />


                                                    <hideSlide3
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                        name="./hideSlide3"
                                                        text="Hide Slide 3"
                                                        value="true"
                                                        uncheckedValue="false" />


                                                    <hideSlide4
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                        name="./hideSlide4"
                                                        text="Hide Slide 4"
                                                        value="true"
                                                        uncheckedValue="false" />


                                                    <hideSlide5
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                        name="./hideSlide5"
                                                        text="Hide Slide 5"
                                                        value="true"
                                                        uncheckedValue="false" />

                                                    <hideSlide6
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                        name="./hideSlide6"
                                                        text="Hide Slide 6"
                                                        value="true"
                                                        uncheckedValue="false" />

                                                </items>
                                            </slideVisibility>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </slidesTab>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>