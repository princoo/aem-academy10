<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0"
    xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    sling:resourceType="cq/gui/components/authoring/dialog"
>
    <content jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container"
    >
        <items jcr:primaryType="nt:unstructured">
            <tabs jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <listSettings jcr:primaryType="nt:unstructured"
                        jcr:title="List Settings"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true"
                    >
                        <items jcr:primaryType="nt:unstructured">
                            <columns jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true"
                            >
                                <items jcr:primaryType="nt:unstructured">
                                    <column jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container"
                                    >
                                        <items jcr:primaryType="nt:unstructured">
                                            <courseFolder jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                fieldLabel="Course Path"
                                                rootPath="/content"
                                                name="./coursePath" />
                                            <maxItems
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                                fieldDescription="Select the number of courses to display (Max 9)"
                                                fieldLabel="Number of Items"
                                                min="{Long}1"
                                                max="{Long}9"
                                                name="./maxItems"
                                                defaultValue="{Long}9" />
                                            <sortOrder jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                fieldLabel="Sort Order"
                                                fieldDescription="Choose the sort order for the courses based on their start date"
                                                name="./sortOrder">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <asc jcr:primaryType="nt:unstructured"
                                                        text="Soonest First (Ascending)"
                                                        value="asc" />
                                                    <desc jcr:primaryType="nt:unstructured"
                                                        text="Furthest First (Descending)"
                                                        value="desc" />
                                                </items>
                                            </sortOrder>
                                            <includeOngoingCourses jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                fieldLabel="Include Ongoing Courses"
                                                fieldDescription="Include courses that are currently ongoing"
                                                name="./includeOngoingCourses"
                                                text="Include Ongoing Courses"
                                                value="{Boolean}true"
                                                uncheckedValue="{Boolean}false"
                                            />
                                            <tags
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="cq/gui/components/coral/common/form/tagfield"
                                                fieldLabel="Filter by Tags"
                                                fieldDescription="Only courses with these tags will be shown. Leave empty to show all."
                                                name="./selectedTags"
                                                multiple="{Boolean}true"
                                                rootPath="/content/cq:tags/wknd" />
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </listSettings>


                </items>
            </tabs>
        </items>
    </content>
</jcr:root>